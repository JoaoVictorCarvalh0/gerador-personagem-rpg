{
  "expo": {
    "name": "RPG Character Generator",
    "slug": "rpg-character-generator",
    "version": "1.0.0",
    "scheme": "rpgchargen",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rpgchargen.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0d0d1a"
      },
      "package": "com.rpgchargen.app"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
